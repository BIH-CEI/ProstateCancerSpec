@startuml RadicalProstatectomy_Structure
' layout: default (GraphViz)
title Radical Prostatectomy – FHIR Resource Structure

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam ArrowColor #555555
skinparam ArrowThickness 1.2
skinparam nodesep 30
skinparam ranksep 40
skinparam padding 5

skinparam rectangle {
  RoundCorner 8
  BorderThickness 1.5
}

' ====================================================================
' TOP: Administrative resources (above DiagnosticReport)
' ====================================================================
together {
  rectangle "**Patient**\nPatient1\nHans Mueller\ngeb. 1955-08-15" as PAT #D6D6D6
  rectangle "**Practitioner**\nPathologistPractitioner\nPathology dept." as PRAC #D6D6D6
  rectangle "**Organization**\nPathologyLabOrganization\nPathology institute" as ORG #D6D6D6
  rectangle "**Encounter**\nRadicalProstatectomyEncounter\n2024-03-15" as ENC #D6D6D6
}

' ====================================================================
' CENTER: DiagnosticReport
' ====================================================================
rectangle "**DiagnosticReport**\nRadicalProstatectomyReport\n────────────────────\ncode: LOINC 60568-3\nidentifier: E_24_002  |  status: final\neffective: 2024-03-20" as DR #C6EFCE

PAT  <-- DR : subject
PRAC <-- DR : performer
ORG  <-- DR : (organization)
ENC  <-- DR : encounter

' ====================================================================
' ServiceRequest
' ====================================================================
rectangle "**ServiceRequest**\nRadicalProstatectomyReportRequest\n────────────\ncode: LOINC 60568-3\nPathology synoptic report\nplacer-ID: PATH-RPT-2024-002" as SR #BDD7EE

' ====================================================================
' Diagnosis (supportingInfo of ServiceRequest)
' ====================================================================
rectangle "**Condition**\nRadicalProstatectomyDiagnosisPreOp\n────────────\nICD-10-GM C61\nProstatakarzinom\nclinicalStatus: active\nstage: IIA (AJCC)" as DIAG #FFF2CC

' ====================================================================
' PSA Post-Op (Follow-up)
' ====================================================================
rectangle "**Observation**\nRadicalProstatectomyPSAPostoperative\n────────────\nLOINC 2857-1\nPSA [Mass/volume]\nvalue: 0.02 ng/mL\neffective: 2024-04-26" as PSA #FFF2CC

' ====================================================================
' Specimens (grouped by anatomical origin)
' ====================================================================
rectangle "Specimens – Prostata" as COL_SPEC_P #FEF5EC {
  rectangle "**Part Specimen**\nOP24_001_A / E_24_002_A\ntype: radical prostatectomy\nadditive: formalin" as SPART_P #FCE4D6

  rectangle "**Block Specimen** (01–03)\nE_24_002_A_1 – _3\ntype: FFPE block\nadditive: paraffin" as SBLOCK_P #FCE4D6

  rectangle "**Slide Specimen** (01A–03B)\nE_24_002_A_*_*HE\ntype: tissue section\nprocessing: HE stain" as SSLIDE_P #FCE4D6

  SPART_P -[hidden]down-> SBLOCK_P
  SBLOCK_P -[hidden]down-> SSLIDE_P
  SSLIDE_P -up-> SBLOCK_P : parent
  SBLOCK_P -up-> SPART_P : parent
}

rectangle "Specimens – Lymphknoten" as COL_SPEC_LK #FEF5EC {
  rectangle "**Part Specimen** (R + L)\nOP24_001_B / _C\ntype: pelvic lymph node\nlaterality: R / L" as SPART_LK #FCE4D6

  rectangle "**Block Specimen** (R + L)\nE_24_002_B_1 / _C_1\ntype: FFPE block\nadditive: paraffin" as SBLOCK_LK #FCE4D6

  rectangle "**Slide Specimen** (R01–L02)\nE_24_002_B/C_1_*HE\ntype: tissue section\nprocessing: HE stain" as SSLIDE_LK #FCE4D6

  SPART_LK -[hidden]down-> SBLOCK_LK
  SBLOCK_LK -[hidden]down-> SSLIDE_LK
  SSLIDE_LK -up-> SBLOCK_LK : parent
  SBLOCK_LK -up-> SPART_LK : parent
}

DR --> SR              : basedOn
DR --> COL_SPEC_P      : specimen
DR --> COL_SPEC_LK     : specimen
SR --> DIAG            : supportingInfo
SR --> PSA             : supportingInfo

' ====================================================================
' Macroscopy-Grouper
' ====================================================================
rectangle "**Macroscopy-Grouper**\nRadicalProstatectomyMacroscopicGrouper\n────────────\nLOINC 22634-0\nresult[macroscopic-observations]" as MACG #E8F4FD {

  rectangle "**Findings** (8)\nProstateWeight  (LOINC 29638-4, 55g)\nProstateWidth  (84894-5, 4.5cm)\nProstateHeight  (84894-5, 4.0cm)\nProstateDepth  (84894-5, 3.5cm)\nLymphNodesPresent  (Present)\nLymphNodesLaterality  (LOINC 20228-3, bilateral)\nSeminalVesiclesPresent  (Present)\nSeminalVesicleLength  (R 2.5cm, L 2.5cm)" as MOBS #E2D0F0
}

DR --> MACG : result

' ====================================================================
' DiagnosticConclusion-Grouper
' ====================================================================
rectangle "**DiagnosticConclusion-Grouper**\nRadicalProstatectomyDiagnosticConclusionGrouper\n────────────\nLOINC 22637-3\nresult[diagnostic-conclusion]" as DCG #FEF0E7 {

  rectangle "**Findings** (21)\nHistologicalType  (LOINC 59847-4, ICD-O-3 8140/3)\nMorphologyFreeText  (LOINC 33731-1)\nICDO Version  (ICD-O-3.2)\nPrimaryGleason  (LOINC 44641-9, Pattern 2)\nSecondaryGleason  (LOINC 44642-7, Pattern 4)\nGleasonScoreTotal  (LOINC 35266-6, Score 7)\nPercentageGleason45  (LOINC 94735-8, 30%)\nGradingGroupISUP  (Grade Group 2)\nIntraductalCarcinoma  (Absent)\nInvasiveCribriformCarcinoma  (Absent)\nMaxTumorDiameter  (LOINC 33728-7, 18mm)\nProstaticTissueInvolved  (LOINC 44654-2, 25%)\nExtraprostaticExtension  (LOINC 44625-2, Absent)\nSeminalVesicleInvasion  (LOINC 44626-0, Absent)\nLymphovascularInvasion  (LOINC 33761-8, Absent)\nPerineuralInfiltration  (LOINC 92837-4, Absent)\nBladderNeckInvasion  (LOINC 84906-7, Absent)\nMarginStatus  (LOINC 84905-9, R0)\nLymphNodesExamined  (LOINC 21894-1, 12)\nLymphNodesPositive  (LOINC 21893-3, 0)\nTNM pT2 pN0" as DCOBS #FFF2CC
}

DR --> DCG : result

' ====================================================================
' Composition
' ====================================================================
rectangle "**Composition**\nRadicalProstatectomyComposition\n────────────────────\ntype: LOINC 11526-1 (Pathology study)\ntitle: Histopathologischer Befundbericht\nauthor: PathologyLabOrganization\nsection.entry -> RadicalProstatectomyReport\nevent.detail -> ServiceRequest" as COMP #C6EFCE

COMP --> DR : section.entry

' ====================================================================
' Bundle
' ====================================================================
rectangle "**Bundle**\nRadicalProstatectomyDocument\n────────────────────\ntype: document\nidentifier: E_24_002\ntimestamp: 2024-03-21\n\nentry[0]: Composition\nentry[1]: Patient\nentry[2]: Organization\nentry[3]: DiagnosticReport\nentry[4]: DiagConclusionGrouper\nentry[5]: MacroscopicGrouper\nentry[6]: Encounter\nentry[7]: ServiceRequest" as BUNDLE #EEEEEE

BUNDLE --> COMP : entry[0]

' ====================================================================
' QuestionnaireResponse
' ====================================================================
rectangle "**QuestionnaireResponse**\nQuestionnaireResponseRadicalProstatectomy\n────────────\nQuestionnaireRadicalProstatectomy\n(whole case)" as QR #FFF2CC

MOBS  --> QR : derivedFrom
DCOBS --> QR : derivedFrom

' ====================================================================
' Layout ordering
' ====================================================================
SR          -[hidden]right-> COL_SPEC_P
COL_SPEC_P  -[hidden]right-> COL_SPEC_LK
COL_SPEC_LK -[hidden]right-> MACG
MACG        -[hidden]right-> DCG
PSA         -[hidden]right-> DIAG

@enduml
